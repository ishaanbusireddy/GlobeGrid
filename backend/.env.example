# TalkDiplomacy Live — environment variables (Section 7.1).
# Zero-install adaptation: SQLite file instead of PostgreSQL (see CLAUDE.md).
DATABASE_URL=sqlite:///backend/data/talkdiplomacy_live.db
# v6.5 — llm_provider.primary is "ollama_local": AI runs on YOUR machine via
# Ollama — free forever, no key, no rate limits, fully private. Setup:
#   1. install from https://ollama.com  (Windows/Mac/Linux)
#   2. run:  ollama pull llama3.1      (~4.9 GB, one time)
# GlobeGrid finds the server automatically. These two are only needed if
# Ollama runs on a non-default host/port or you want a different model
# (also settable via backend/config.yaml llm_provider.ollama_model):
#OLLAMA_HOST=http://localhost:11434
#OLLAMA_MODEL=llama3.1
# Cloud fallback (optional): with a Groq key set, GlobeGrid transparently
# uses Groq whenever local Ollama isn't running (free tier ~100k tokens/day).
# Any one key is enough; more keys extend the automatic fallback chain
# (backend/config.yaml llm_provider.fallback_order).
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
# Optional upgrade: swap the Claude provider in for higher-quality prose with
# no daily-quota ceiling (costs per request). Leave blank to stay on the free
# default above.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
ALPHAVANTAGE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=talkdiplomacy-live/1.0 (single-user local build)
# v2 addendum sources (all optional; sources show degraded until set)
FIRMS_MAP_KEY=
ACLED_KEY=
ACLED_EMAIL=
# v3 §4: multilingual model so non-English sources correlate by meaning;
# the whole fact chain re-embeds automatically on model change
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
API_PORT=8000
WS_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./logs
